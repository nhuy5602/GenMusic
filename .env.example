# === Local Processing Paths ===
# Directory containing raw audio files (.wav, .mp3)
RAW_AUDIO_INPUT_DIR=dataset/vietnamese_songs

# Output directory for the preprocessed and labeled dataset
PROCESSED_DATASET_DIR=dataset/diff_rhythm_dataset

# Path where trained model checkpoints are stored locally
MODEL_CHECKPOINT_PATH=outputs/my_trained_model.pt

# === Kaggle Credentials & Configurations ===
# Your Kaggle username
KAGGLE_USERNAME=your_kaggle_username

# Your current Kaggle access token (currently starts with KGAT_; KGAT- is also accepted)
KAGGLE_API_TOKEN=KGAT_your_kaggle_access_token
# Legacy API credentials remain supported when KAGGLE_API_TOKEN is absent:
# KAGGLE_KEY=your_legacy_kaggle_api_key

# The raw audio dataset on Kaggle to load files from
KAGGLE_RAW_DATASET_REF=sonlest/vietnamese-music-dataset-version3-part6

# Preferred: ref of a preprocess-kernel run (run_kaggle_preprocess_all.py), attached to
# downstream train/distill kernels via kernel_sources -- no Kaggle Dataset upload, no
# credentials embedded in the shared kernel code. Set this after a preprocess run.
KAGGLE_PROCESSED_KERNEL_REF=your_kaggle_username/genmusic-prep-1234567890

# Legacy fallback: a pre-existing published Dataset with processed data (attached via
# dataset_sources instead). Only used if KAGGLE_PROCESSED_KERNEL_REF is unset.
KAGGLE_PROCESSED_DATASET_REF=your_kaggle_username/vietnamese-music-processed-dataset

# The fixed training dataset ref used by stage commands
GENMUSIC_KAGGLE_DATASET_REF=your_kaggle_username/genmusic-vn-self-diffusion-training

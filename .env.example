# Sao chep file nay thanh .env hoac .env.local, sau do dien Kaggle API token.
# Khong commit .env/.env.local vao kho ma nguon.

GENMUSIC_OUTPUT_DIR=outputs
GENMUSIC_DEFAULT_DURATION=30

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
GENMUSIC_KAGGLE_DATASET_REF=your_kaggle_username/genmusic-vn-self-diffusion-training
